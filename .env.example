# Email Configuration (for lead notifications)
# Using Gmail or your own SMTP server
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=your-email@gmail.com

# Where to send lead notifications
LEAD_EMAIL=your-email@gmail.com
LEAD_PHONE=+18325551234

# Twilio Configuration (optional - for SMS notifications)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+18325551234
